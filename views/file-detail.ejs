<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= file.name %> - Drivebox</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <%- include('shared/layout')%>

    <main class="file-detail-wrapper">
      <div>
        <ul>
          <li><span>Name</span> <%= file.name %></li>
          <li><span>Type</span> <%= file.mimeType %></li>
          <li><span>Size</span> <%= (file.size / 1024).toFixed(2) %> KB</li>
          <li>
            <span>Added</span> <%= new
            Date(file.uploadedAt).toLocaleString() %>
          </li>
        </ul>
        <div class="file-detail__btn-wrapper">
          <a href="/files/<%= file.id %>/download" class="file-detail__btn download"><i data-feather="download" class="btn-feather-icon"></i>&ensp;Download</a>
          <form
            action="/files/<%= file.id %>/delete"
            method="post"
            onsubmit="
              return confirm(
                'Are you sure you want to delete the file: <%= file.name %>?',
              );
            "
          >
            <button type="submit" class="file-detail__btn delete">Delete file</button>
          </form>
        </div>
      </div>

      <% if (file.mimeType && file.mimeType.startsWith('image/')) { %>
        <img src="<%= supabaseUrl %>/storage/v1/object/public/uploads/<%= file.path %>" alt="<%= file.name %>" style="max-width: 100%; max-height: 500px; display: block; margin-bottom: 1rem;" />
      <% } else { %>
        <img src="/images/save.png" alt="File icon" style="width: 80px; height: 80px; display: block; margin-bottom: 1rem;" />
      <% } %>
    </main>
    <%- include('shared/footer') %>
  </body>
</html>
