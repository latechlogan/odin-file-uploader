<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title><%= file.name %> - Drivebox</title>
    <link rel="stylesheet" href="/style.css" />
  </head>
  <body>
    <%- include('shared/layout')%>

    <main style="padding: 2rem">
      <h2><%= file.name %></h2>
      <ul>
        <li><strong>Name:</strong> <%= file.name %></li>
        <li><strong>Type:</strong> <%= file.mimeType %></li>
        <li><strong>Size:</strong> <%= (file.size / 1024).toFixed(2) %> KB</li>
        <li>
          <strong>Uploaded:</strong> <%= new
          Date(file.uploadedAt).toLocaleString() %>
        </li>
      </ul>
      <% if (file.mimeType && file.mimeType.startsWith('image/')) { %>
        <img src="<%= supabaseUrl %>/storage/v1/object/public/uploads/<%= file.path %>" alt="<%= file.name %>" style="max-width: 100%; max-height: 500px; display: block; margin-bottom: 1rem;" />
      <% } else { %>
        <img src="/images/save.png" alt="File icon" style="width: 80px; height: 80px; display: block; margin-bottom: 1rem;" />
      <% } %>
      <a href="/files/<%= file.id %>/download">Download</a>
      <form
        action="/files/<%= file.id %>/delete"
        method="post"
        onsubmit="
          return confirm(
            'Are you sure you want to delete the file: <%= file.name %>?',
          );
        "
      >
        <button type="submit" class="folder-detail__button">Delete File</button>
      </form>
    </main>
    <%- include('shared/footer') %>
  </body>
</html>
