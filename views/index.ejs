<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Drivebox</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <%- include('shared/layout') %>

  <% if (user) { %>
    <main class="main-content-wrapper">

      <% if (search) { %>
        <p>Showing results for "<%= search %>"</p>
        <a href="<%= currentPath %>">Clear</a>
      <% } %>

      <div class="view-toggle">
        <a href="/?<%= search ? 'search=' + encodeURIComponent(search) + '&' : '' %>view=separate" class="view-toggle__link<%= viewMode === 'separate' ? ' view-toggle__link--active' : '' %>">Grouped</a>
        <a href="/?<%= search ? 'search=' + encodeURIComponent(search) + '&' : '' %>view=combined" class="view-toggle__link<%= viewMode === 'combined' ? ' view-toggle__link--active' : '' %>">Combined</a>
      </div>

      <% if (viewMode === 'combined') { %>
        <%
          const combined = [
            ...files.map(f => ({ ...f, type: 'file' })),
            ...folders.map(f => ({ ...f, type: 'folder' }))
          ].sort((a, b) => a.name.localeCompare(b.name));
        %>
        <% if (combined.length > 0) { %>
          <section class="files">
            <ul class="files-grid">
              <% combined.forEach(item => { %>
                <% if (item.type === 'file') { %>
                  <li>
                    <a href="/files/<%= item.id %>" class="file-elements">
                      <div class="img-wrapper">
                        <% if (item.mimeType && item.mimeType.startsWith('image/')) { %>
                          <img src="<%= supabaseUrl %>/storage/v1/object/public/uploads/<%= item.path %>" alt="<%= item.name %>" class="file-icon">
                        <% } else { %>
                          <img src="/images/save.png" alt="" class="file-icon">
                        <% } %>
                      </div>
                      <span class="file-name"><%= item.name %></span>
                    </a>
                  </li>
                <% } else { %>
                  <li>
                    <a href="/folders/<%= item.id %>" class="folder-elements">
                      <div class="img-wrapper">
                        <img src="/images/folder.png" alt="" class="folder-icon">
                      </div>
                      <span class="folder-name"><%= item.name %></span>
                    </a>
                  </li>
                <% } %>
              <% }) %>
            </ul>
          </section>
        <% } %>
      <% } else { %>

        <% if (files.length > 0) { %>
          <section class="files">
            <h2 class="files-heading">Files</h2>
            <ul class="files-grid">
              <% files.forEach(file => { %>
                <li>
                  <a href="/files/<%= file.id %>" class="file-elements">
                    <div class="img-wrapper">
                      <% if (file.mimeType && file.mimeType.startsWith('image/')) { %>
                        <img src="<%= supabaseUrl %>/storage/v1/object/public/uploads/<%= file.path %>" alt="<%= file.name %>" class="file-icon">
                      <% } else { %>
                        <img src="/images/save.png" alt="" class="file-icon">
                      <% } %>
                    </div>
                    <span class="file-name"><%= file.name %></span>
                  </a>
                </li>
              <% }) %>
            </ul>
          </section>
        <% } %>

        <% if (folders.length > 0) { %>
          <section class="folders">
            <h2 class="folders-heading">Folders</h2>
            <ul class="folders-grid">
              <% folders.forEach(folder => { %>
                <li>
                  <a href="/folders/<%= folder.id %>" class="folder-elements">
                    <div class="img-wrapper">
                      <img src="/images/folder.png" alt="" class="folder-icon">
                    </div>
                    <span class="folder-name"><%= folder.name %></span>
                  </a>
                </li>
              <% }) %>
            </ul>
          </section>
        <% } %>

      <% } %>
    </main>
  <% } else { %>
    <main class="content-card-wrapper">
      <%- include('shared/login-form') %>
    </main>
  <% } %>
  <%- include('shared/footer') %>
</body>
</html>
